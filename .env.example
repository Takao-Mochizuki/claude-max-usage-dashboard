# Claude Max Usage Dashboard — Configuration
# Copy this file to .env and fill in your tokens.
#
# How to get your token:
#   1. Open terminal
#   2. Run: claude setup-token
#   3. Copy the token (starts with sk-ant-oat01-)
#
# You need one token per Claude Max account.

# Account 1
C1_TOKEN=sk-ant-oat01-your-token-here
C1_LABEL=Account 1

# Account 2
C2_TOKEN=sk-ant-oat01-your-token-here
C2_LABEL=Account 2

# (Optional) More accounts — up to C9
# C3_TOKEN=sk-ant-oat01-...
# C3_LABEL=Account 3

# (Optional) Server port (default: 18800)
# PORT=18800
